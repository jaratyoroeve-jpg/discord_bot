# systemd ドロップイン（環境変数）テンプレート
# 配置先: /etc/systemd/system/discord-bot.service.d/env.conf
# 編集後: sudo systemctl daemon-reload && sudo systemctl restart discord-bot
#
# 値にスペースを含む場合は KEY=VALUE 全体をダブルクオートで囲む。

[Service]
Environment=DISCORD_BOT_TOKEN=your_discord_bot_token
Environment=ANTHROPIC_API_KEY=your_anthropic_api_key
Environment=ANTHROPIC_MODEL=claude-sonnet-4-6
Environment="SYSTEM_PROMPT=You are a helpful assistant."
